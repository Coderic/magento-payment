<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="wompi_payment" translate="label comment" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Wompi (Colombia)</label>
                <comment>Web Checkout Wompi. Configure llaves de sandbox y producción; active el entorno con «Modo de prueba».</comment>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="business_model" translate="label comment" type="select" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Plan Wompi</label>
                    <comment>Agregador: Wompi facilita medios de pago. Gateway: adquirencia propia con Bancolombia.</comment>
                    <source_model>Wompi\Payment\Model\Config\Source\BusinessModel</source_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Title</label>
                </field>
                <field id="test_mode" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Modo de prueba</label>
                    <comment>Sandbox o producción. Ambos juegos de llaves pueden guardarse; este selector define cuál usa el checkout.</comment>
                    <source_model>Wompi\Payment\Model\Config\Source\Environment</source_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="sandbox_keys_heading" translate="label" sortOrder="35" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Sandbox (pruebas)</label>
                    <frontend_model>Magento\Config\Block\System\Config\Form\Field\Heading</frontend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="public_key_test" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Public key</label>
                    <comment>Llave pública del API (`pub_test_*`). Mismo orden que el panel Wompi.</comment>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="private_key_test" translate="label comment" type="obscure" sortOrder="41" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Private key</label>
                    <comment>Llave privada del API (`prv_test_*`).</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="events_key_test" translate="label comment" type="obscure" sortOrder="42" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Events</label>
                    <comment>Secreto de eventos para webhooks (`test_events_*`).</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="integrity_key_test" translate="label comment" type="obscure" sortOrder="43" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Integrity</label>
                    <comment>Secreto de integridad para Web Checkout (`test_integrity_*`).</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="production_keys_heading" translate="label" sortOrder="49" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Producción</label>
                    <frontend_model>Magento\Config\Block\System\Config\Form\Field\Heading</frontend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="public_key_production" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Public key</label>
                    <comment>Llave pública del API (`pub_prod_*`). Mismo orden que el panel Wompi.</comment>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="private_key_production" translate="label comment" type="obscure" sortOrder="51" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Private key</label>
                    <comment>Llave privada del API (`prv_prod_*`).</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="events_key_production" translate="label comment" type="obscure" sortOrder="52" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Events</label>
                    <comment>Secreto de eventos para webhooks (`prod_events_*`).</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="integrity_key_production" translate="label comment" type="obscure" sortOrder="53" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Integrity</label>
                    <comment>Secreto de integridad para Web Checkout (`prod_integrity_*`).</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="acquirer_merchant_id" translate="label comment" type="text" sortOrder="120" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Gateway merchant ID</label>
                    <comment>Reservado Plan Gateway. Completar cuando Wompi especifique el campo.</comment>
                    <depends>
                        <field id="active">1</field>
                        <field id="business_model">gateway</field>
                    </depends>
                </field>
                <field id="store_view_code" translate="label comment" type="text" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Restrict to store view code</label>
                    <comment>Optional. Leave empty to show Wompi on every store view.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
