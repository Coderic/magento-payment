<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="wompi_payment" translate="label comment" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Wompi (Colombia)</label>
                <comment>Web Checkout Wompi. Configure llaves de sandbox y producción; active el entorno con «Modo de prueba».</comment>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="business_model" translate="label comment" type="select" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Plan Wompi</label>
                    <comment>Agregador: Wompi facilita medios de pago. Gateway: adquirencia propia con Bancolombia.</comment>
                    <source_model>Wompi\Payment\Model\Config\Source\BusinessModel</source_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Title</label>
                </field>
                <field id="test_mode" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Modo de prueba</label>
                    <comment>Sandbox: llaves pub_test_*. Producción: llaves pub_prod_*. Ambos juegos pueden guardarse a la vez.</comment>
                    <source_model>Wompi\Payment\Model\Config\Source\Environment</source_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="public_key_test" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Public key (sandbox)</label>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="public_key_production" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Public key (production)</label>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="private_key_test" translate="label" type="obscure" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Private key (sandbox)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="private_key_production" translate="label" type="obscure" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Private key (production)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="integrity_key_test" translate="label" type="obscure" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Integrity secret (sandbox)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="integrity_key_production" translate="label" type="obscure" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Integrity secret (production)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="events_key_test" translate="label" type="obscure" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Events secret (sandbox)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="events_key_production" translate="label" type="obscure" sortOrder="110" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Events secret (production)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <field id="acquirer_merchant_id" translate="label comment" type="text" sortOrder="120" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Gateway merchant ID</label>
                    <comment>Reservado Plan Gateway. Completar cuando Wompi especifique el campo.</comment>
                    <depends>
                        <field id="active">1</field>
                        <field id="business_model">gateway</field>
                    </depends>
                </field>
                <field id="store_view_code" translate="label comment" type="text" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Restrict to store view code</label>
                    <comment>Optional. Leave empty to show Wompi on every store view.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
